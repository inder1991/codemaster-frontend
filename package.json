{
  "name": "codemaster-admin",
  "version": "0.1.0",
  "private": true,
  "description": "codemaster admin console — Sprint 12 / S12.1.1",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "openapi-typescript contracts/openapi.json -o src/lib/api/generated/contracts.ts",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:tests": "tsc --noEmit",
    "tsc:ci": "tsc --noEmit -p tsconfig.typecheck.json --pretty false",
    "license-check": "license-checker --onlyAllow \"$(cat licenses-allowed.txt | tr '\\n' ';')\" --excludePrivatePackages",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@headlessui/react": "^2.1.0",
    "@heroicons/react": "^2.1.0",
    "@tanstack/react-query": "^5.51.0",
    "@uiw/react-codemirror": "^4.25.9",
    "boring-avatars": "^2.0.4",
    "next": "^15.0.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-sanitize": "^6.0.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.0",
    "@storybook/nextjs": "^8.3.0",
    "@storybook/react": "^8.3.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "axe-core": "^4.10.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "jsdom": "^25.0.0",
    "license-checker": "^25.0.1",
    "openapi-typescript": "^7.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "vitest-axe": "^0.1.0"
  }
}
